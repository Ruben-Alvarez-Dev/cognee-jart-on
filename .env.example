# COGNEE-jart-on environment variables
# Copy this file to .env and fill in real values before starting services.
# NEVER commit .env to version control.

# PostgreSQL
POSTGRES_PASSWORD=changeme

# Neo4j
NEO4J_PASSWORD=changeme

# LiteLLM proxy master key (used by docker-compose and litellm_config.yaml)
LITELLM_MASTER_KEY=changeme

# Gemini API key (used by LiteLLM for LLM calls)
GEMINI_API_KEY=
