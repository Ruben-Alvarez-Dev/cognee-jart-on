# COGNEE-jart-on environment variables
# Copy this file to .env and fill in real values before starting services.
# NEVER commit .env to version control.

# PostgreSQL
POSTGRES_PASSWORD=changeme

# Neo4j
NEO4J_PASSWORD=changeme

# LiteLLM proxy master key. The python client authenticates with this same
# value (its api_key defaults to LITELLM_MASTER_KEY). To change it, export it
# in your shell so BOTH docker-compose and the client pick it up; the default
# is "sk-litellm".
LITELLM_MASTER_KEY=sk-litellm

# Gemini API key (used by LiteLLM for LLM calls)
GEMINI_API_KEY=
